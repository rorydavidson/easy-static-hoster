# Copy to .env and adjust values

# Host path to your content directory
CONTENT_DIR=./content

# Title shown in the index page header
SITE_TITLE=EasyHoster

# Host port to expose (default: 8080)
PORT=8080

# Optional: enable HTTP Basic Auth (format: username:password)
# Leave unset or empty to disable auth entirely.
# When set, the upload button is shown and /api/upload requires credentials.
# BASIC_AUTH=admin:changeme

# Optional: lock the entire site behind Basic Auth (requires BASIC_AUTH to be set)
# AUTH_GLOBAL=true

# ── OIDC / SSO settings (use with docker-compose.oidc.yml) ──────────────────
# When set, oauth2-proxy handles authentication via Keycloak, Google, Azure AD,
# or any OIDC-compatible provider. Mutually exclusive with BASIC_AUTH.
#
# OIDC_ISSUER_URL=https://keycloak.example.com/realms/myrealm
# OIDC_CLIENT_ID=easy-hoster
# OIDC_CLIENT_SECRET=your-client-secret
# COOKIE_SECRET=generate-with: openssl rand -base64 24
# OIDC_COOKIE_SECURE=false   # set true when behind TLS
# OIDC_ALLOWED_GROUP=easyhoster-users   # OIDC group required for access
# OIDC_GROUPS_CLAIM=groups              # JWT claim containing group list (default: groups)

# ── nginx-proxy settings (only needed with docker-compose.nginx-proxy.yml) ──

# Public hostname nginx-proxy should route to this instance
# VIRTUAL_HOST=reports.example.com

# Docker network that nginx-proxy is attached to (default: nginx-proxy)
# PROXY_NETWORK=nginx-proxy

# Optional: auto-TLS via acme-companion
# LETSENCRYPT_HOST=reports.example.com
# LETSENCRYPT_EMAIL=you@example.com
